{
  "name": "server",
  "version": "1.0.0",
  "main": "app.js",
  "license": "MIT",
  "scripts": {
    "build": "yarn clean && tsc",
    "dev": "tsx watch --env-file=.env.dev src/app.ts",
    "dev:docker": "RUNNING_IN_DOCKER=true tsx watch --env-file=.env.dev src/app.ts",
    "clean": "rm -rf dist",
    "start": "node dist/app.js",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix --cache",
    "type-check": "tsc --noEmit",
    "migrate:create": "tsx migrate.js create --prefix TIMESTAMP --folder src/database/migrations --name",
    "migrate:dev": "dotenv -e .env.dev -- tsx migrate.js up",
    "migrate:pending": "dotenv -e .env.dev -- tsx migrate.js pending",
    "migrate:down": "dotenv -e .env.dev -- tsx migrate.js down --name"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/http-proxy": "^11.4.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/type-provider-typebox": "^6.1.0",
    "dotenv": "^17.4.1",
    "fastify": "^5.8.4",
    "fastify-cli": "^8.0.0",
    "fastify-plugin": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "tsx": "^4.21.0",
    "typebox": "^1.1.23",
    "umzug": "^3.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "sequelize-cli": "^6.6.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
